import time
import sys # Added import for sys module
h=1
m=2
s=0
while True:
    sys.stdout.write("\r{:02d} : {:02d} : {:02d}".format(h,m,s)) # Corrected format string
    sys.stdout.flush()
    time.sleep(1)
    s=s+1
    if s==60:
        s=0
        m=m+1
    if m==60:
        m=0
        h=h+1
    if h==12: # Corrected indentation
        h=0
