#a poultry farm has group of hens and cows..
#need to find num of cows and hens separatly ,
#if total legs &total heads together given :
# testcase 1: legs: 16
              #heads: 6
              #cows =2
              #hens =4
legs =int(input("enter no of legs: "))
heads =int(input("enter no of heads: "))
flag=False
for cows in range(0,heads + 1):
    hens = heads - cows
    cal_legs=cows*4 + hens*2
    if cal_legs==legs: 
        flag=True
        break
if flag:
        print("cows =", cows)
        print("hens =", hens)
else:
  print("no solution ")
